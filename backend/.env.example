APP_NAME="Correspondencia Unificada"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# URL pública de verificación de documentos (QR). Debe ser la URL pública real
# (ej: https://verificar.imcabodehornos.cl), ya que se imprime en los documentos.
VERIFICACION_BASE_URL=https://verificar.imcabodehornos.cl

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=correspondencia_unificada
DB_USERNAME=unificada_user
DB_PASSWORD=unificada_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8000

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="sistema@municipalidad.cl"
MAIL_FROM_NAME="${APP_NAME}"

FIRMAGOB_URL=https://api.firmagob.cl
FIRMAGOB_API_KEY=
